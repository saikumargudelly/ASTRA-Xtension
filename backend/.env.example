# ─── NEXUS Backend Environment Template ────────────────────────────────────────
# Copy this to .env and fill in your values

# === LLM Providers ===
# Primary (planning, reasoning, code) — Required for full NEXUS
ANTHROPIC_API_KEY=sk-ant-

# Vision tasks (optional — falls back to Fireworks if not set)
OPENAI_API_KEY=sk-

# Fallback / simple-qa / legacy ASTRA compatibility
FIREWORKS_API_KEY=fw-
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct  # Text tasks fallback
QWEN_API_KEY=                         # Alias for FIREWORKS_API_KEY (legacy)
QWEN_API_URL=https://api.fireworks.ai/inference/v1/chat/completions
QWEN_MODEL=accounts/fireworks/models/qwen3-8b

# Local / privacy mode (optional — requires Ollama running)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Vision model for screenshot analysis
VISION_MODEL=accounts/fireworks/models/qwen3-vl-30b-a3b-instruct

# === Privacy Mode ===
# cloud       → use cloud LLMs (Anthropic/OpenAI/Fireworks)
# hybrid      → cloud for non-sensitive, Ollama for sensitive
# local-only  → always use Ollama
PRIVACY_MODE=cloud

# === Databases ===
# PostgreSQL (Tier 3 Semantic Memory) — start with: docker compose up postgres -d
POSTGRES_URL=postgresql://nexus:nexus@localhost:5432/nexus

# Redis (Tier 1 Working Memory) — start with: docker compose up redis -d
REDIS_URL=redis://localhost:6379

# ChromaDB (Tier 2 Episodic Memory) — start with: docker compose up chroma -d
CHROMA_URL=http://localhost:8000

# === Server ===
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# === Groq (Legacy — only if you were using Groq before) ===
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=openai/gpt-oss-120b
