{
  "name": "nexus-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "NEXUS – Next-Generation Extensible Universal Assistant",
  "workspaces": [
    "extension",
    "backend"
  ],
  "scripts": {
    "dev:ext": "npm run dev --workspace=extension",
    "dev:backend": "npm run dev --workspace=backend",
    "build:ext": "npm run build --workspace=extension",
    "build:backend": "npm run build --workspace=backend",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:ext\""
  }
}